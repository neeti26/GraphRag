# ── TigerGraph Cloud ──────────────────────────────────────────
TG_HOST=https://your-instance.i.tgcloud.io
TG_USERNAME=tigergraph
TG_PASSWORD=your_password
TG_GRAPH_NAME=FraudGraph
TG_SECRET=your_secret

# ── Gemini (provided by TigerGraph for Round 2) ───────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# ── Fallback LLM (optional) ───────────────────────────────────
OPENAI_API_KEY=
GROQ_API_KEY=

# ── Dataset ───────────────────────────────────────────────────
DATASET_PATH=data/transactions.csv
TOKEN_TARGET=100000000
