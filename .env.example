# TigerGraph (optional — leave as-is to use demo graph data)
TG_HOST=https://your-instance.i.tgcloud.io
TG_USERNAME=tigergraph
TG_PASSWORD=your_password
TG_GRAPH_NAME=FraudGraph
TG_SECRET=your_secret_here

# Gemini (required for real benchmark run)
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
